# Copy to .env and fill in. Only the providers you actually use are required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OpenRouter — one key for Gemini, Grok, DeepSeek, Qwen, Llama, etc.
OPENROUTER_API_KEY=

# For unattended cloud runs (scripts/runpod_*.sh): a GitHub PAT with repo write,
# so the pod can push generated results back to a branch.
# GITHUB_TOKEN=

# Optional: path to a SoundFont for audio rendering (see scripts/setup_soundfont.sh).
# If unset, the pipeline looks in ./soundfonts/ and falls back to skipping audio.
# SOUNDFONT_PATH=
