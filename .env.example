# Copy to .env and fill in. Only the providers you use are required.
ANTHROPIC_API_KEY=

# Optional, for later adapters:
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# Optional: path to a SoundFont for audio rendering (see scripts/setup_soundfont.sh).
# If unset, the pipeline looks in ./soundfonts/ and falls back to skipping audio.
# SOUNDFONT_PATH=
